@startuml

hide empty members
allow_mixing

class scanner {
    + scanner(std::string::const_iterator p_begin, std::string::const_iterator p_end)
    + symbol operator()()
}
class symbol
class lexeme
class token 
class tokens

type *-- recognizer

token *-- "m_size" uint8_t
token *--  type
tokens *-- "*" token

types *-- "*" type

symbol *-- lexeme
symbol *-- type

scanner *-- types
scanner *-- tokens


@enduml